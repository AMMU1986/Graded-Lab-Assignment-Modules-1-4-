amman@amman:~$ # Question 2: Secure Project Workspace Setup
amman@amman:~$ 
amman@amman:~$ # 1. Create directory structure
amman@amman:~$ mkdir -p ~/project_workspace/{docs,src,backups,temp}
amman@amman:~$ mkdir ~/project_workspace/docs/archived
amman@amman:~$ mkdir ~/project_workspace/src/modules
amman@amman:~$ 
amman@amman:~$ # Explanation: Creates a nested directory structure using mkdir -p to create parent directories automatically.
amman@amman:~$ 
amman@amman:~$ # 2. Display directory structure
amman@amman:~$ ls -R ~/project_workspace
