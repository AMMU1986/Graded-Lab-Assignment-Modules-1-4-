amman@amman:~$ # Question 3: File System and Link Analysis
amman@amman:~$ 
amman@amman:~$ # 1. Create directories for the experiment
amman@amman:~$ mkdir -p ~/link_experiment
amman@amman:~$ cd ~/link_experiment
amman@amman:~/link_experiment$ 
amman@amman:~/link_experiment$ # Explanation: Creates a dedicated directory for the link analysis experiment.
amman@amman:~/link_experiment$ 
amman@amman:~/link_experiment$ # 2. Create original file with content
amman@amman:~/link_experiment$ echo "This is the original file content for link analysis" > original.txt
amman@amman:~/link_experiment$ cat original.txt
This is the original file content for link analysis
amman@amman:~/link_experiment$ 
amman@amman:~/link_experiment$ # Explanation: Creates original.txt with sample content, cat displays its contents.
amman@amman:~/link_experiment$ 
amman@amman:~/link_experiment$ # 3. Create a hard link
amman@amman:~/link_experiment$ ln original.txt hardlink.txt
amman@amman:~/link_experiment$ ls -li original.txt hardlink.txt
921402 -rw-rw-r-- 2 amman amman 52 Jul  3 23:40 hardlink.txt
921402 -rw-rw-r-- 2 amman amman 52 Jul  3 23:40 original.txt
amman@amman:~/link_experiment$ 
amman@amman:~/link_experiment$ # Explanation: ln creates a hard link, ls -li shows inode numbers and permissions for both files.
amman@amman:~/link_experiment$ 
amman@amman:~/link_experiment$ # 4. Create a symbolic link
amman@amman:~/link_experiment$ ln -s original.txt symlink.txt
amman@amman:~/link_experiment$ ls -li original.txt hardlink.txt symlink.txt
